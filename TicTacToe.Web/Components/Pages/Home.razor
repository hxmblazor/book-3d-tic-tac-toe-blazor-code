@page "/"

<PageTitle>3D Tic-Tac-Toe</PageTitle>

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-3">🎮 3D Tic-Tac-Toe</h1>
        <p class="lead">Experience the classic game in three dimensions!</p>
        <a href="/play" class="btn btn-primary btn-lg mt-3">Start Playing</a>
    </div>

    <div class="row mt-5">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">🎯 Multiple Board Sizes</h5>
                    <p class="card-text">
                        Choose from 3×3×3, 4×4×4, or 5×5×5 grids. 
                        Each size offers a different level of challenge and strategy.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">🏆 Smart Win Detection</h5>
                    <p class="card-text">
                        Advanced algorithm detects wins across 26 different directions:
                        horizontal, vertical, and diagonal lines through 3D space.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">📱 Responsive Design</h5>
                    <p class="card-text">
                        Play on any device! The game adapts to your screen size,
                        whether on desktop, tablet, or mobile.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">How to Play</h5>
                    <ol>
                        <li>Choose your board size (3×3×3, 4×4×4, or 5×5×5)</li>
                        <li>Click on any cell to place your mark (X or O)</li>
                        <li>Players alternate turns</li>
                        <li>Get a complete line in any direction to win!</li>
                        <li>Lines can be horizontal, vertical, or diagonal (even through layers)</li>
                    </ol>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Features</h5>
                    <ul>
                        <li>✅ Real-time game state updates</li>
                        <li>✅ Move history tracking</li>
                        <li>✅ Session statistics</li>
                        <li>✅ Winning position highlights</li>
                        <li>✅ Clean, modern UI</li>
                        <li>✅ Built with .NET 9 & Blazor Server</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5 mb-5">
        <p class="text-muted">
            <em>"First the engine learned to place. Then it learned to win. Now it learns to inspire."</em>
        </p>
        <p class="text-muted">
            Built with .NET 9 | Based on the book chapters in <code>MarkdownEnhanced-Net10/</code>
        </p>
    </div>
</div>
