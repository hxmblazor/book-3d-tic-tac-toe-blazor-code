    private async void SetCameraView(string view)
    {
        if (module != null && isInitialized)
        {
            await module.InvokeVoidAsync("setCameraView", view);
        }
    }

    private async void SetSliceAxis(string axis)
    {
        sliceAxis = axis;
        if (sliceAxis == "none")
        {
            sliceIndex = 1;
        }
        if (module != null && isInitialized)
        {
            await module.InvokeVoidAsync("setSlice", sliceAxis, sliceIndex);
        }
