    private async void UpdateSliceIndex(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int value))
        {
            await SetSliceIndex(value);
        }
    }

    private async Task SetSliceIndex(int value)
    {
        if (value >= 1 && value <= Session.Board.Size)
        {
            sliceIndex = value;
            if (module != null && isInitialized)
            {
                await module.InvokeVoidAsync("setSlice", sliceAxis, sliceIndex);
            }
        }
    }

    private async void StepSliceIndex(int delta)
    {
        var next = sliceIndex + delta;
        if (next < 1 || next > Session.Board.Size) return;
        await SetSliceIndex(next);
    }

    private string GetBtnClass(int size)
    {
        // Disable board size buttons if game is in progress
        if (isGameInProgress)
        {
            return Session.Board.Size == size ? "btn-secondary disabled" : "btn-outline-secondary disabled";
        }
        return Session.Board.Size == size ? "btn-primary" : "btn-outline-primary";
    }

    private string GetPlayerClass()
    {
        return Session.Board.CurrentPlayer == Player.X ? "text-primary" : "text-warning";
    }

    private string GetSliceBtnClass(string axis)
    {
        return sliceAxis == axis ? "btn-primary" : "btn-outline-primary";
    }

    private void StartMoveConfirmation(int x, int y, int z)
    {
        Console.WriteLine($"[SERVER] StartMoveConfirmation: ({x},{y},{z})");

        // Cancel any existing timer
        confirmationTimer?.Dispose();

        // Set pending move
        pendingMove = (x, y, z);
        countdown = ConfirmationSeconds;

        // Update 3D view to show pending move
        if (module != null && isInitialized)
        {
            _ = module.InvokeVoidAsync("showPendingMove", x, y, z);
        }

        // Start countdown timer (ticks every second)
        confirmationTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                countdown--;
                Console.WriteLine($"[SERVER] Countdown: {countdown}");

                if (countdown <= 0)
                {
                    ConfirmMove();
                }
                else
                {
                    StateHasChanged();
                }
            });
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

        StateHasChanged();
    }

    private void CancelPendingMove()
    {
        Console.WriteLine("[SERVER] CancelPendingMove called");
        confirmationTimer?.Dispose();
        confirmationTimer = null;
        pendingMove = null;
        countdown = 0;

        // Clear pending move in 3D view
        if (module != null && isInitialized)
        {
            _ = module.InvokeVoidAsync("clearPendingMove");
        }

        StateHasChanged();
    }

    [JSInvokable]
    public void ConfirmMoveNow()
    {
        Console.WriteLine("[SERVER] ConfirmMoveNow called - immediate confirmation");
        // Set countdown to 0 to trigger immediate confirmation
        countdown = 0;
        // ConfirmMove() will be called on the next timer tick, or we can call it directly
        ConfirmMove();
    }

    private async void ConfirmMove()
    {
        if (pendingMove == null) return;

        var move = pendingMove.Value;
        Console.WriteLine($"[SERVER] ConfirmMove: ({move.x},{move.y},{move.z})");

        // Clean up timer and clear 3D pending indicator
        confirmationTimer?.Dispose();
        confirmationTimer = null;
        pendingMove = null;
        countdown = 0;

        if (module != null && isInitialized)
        {
            await module.InvokeVoidAsync("clearPendingMove");
        }

        // Use async version for AI support (Chapter 9)
        bool success = await Session.MakeMoveAsync(move.x, move.y, move.z);
        Console.WriteLine($"[SERVER] ConfirmMove: success={success}");

        if (success)
        {
            isGameInProgress = !Session.Board.IsGameOver;
            Console.WriteLine($"[SERVER] ConfirmMove: isGameInProgress set to {isGameInProgress}");

            // After MakeMoveAsync returns (includes AI move), ensure UI + 3D are synced
            await InvokeAsync(async () =>
            {
                StateHasChanged();
                await SyncBoardState();
            });
        }
    }


    public async ValueTask DisposeAsync()
    {
        confirmationTimer?.Dispose();
        Session.OnStateChanged -= OnGameStateChanged;
        dotNetRef?.Dispose();
        if (module != null)
        {
            try
            {
                await module.InvokeVoidAsync("cleanup");
                await module.DisposeAsync();
            }
            catch { }
        }
    }
